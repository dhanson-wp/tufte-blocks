{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "background",
					"color": "#151515",
					"name": "Background"
				},
				{
					"slug": "foreground",
					"color": "#eeeeee",
					"name": "Foreground"
				},
				{
					"slug": "secondary",
					"color": "#a0a0a0",
					"name": "Secondary"
				},
				{
					"slug": "primary",
					"color": "#c9a959",
					"name": "Primary"
				},
				{
					"slug": "primary-hover",
					"color": "#dfc07a",
					"name": "Primary Hover"
				},
				{
					"slug": "border",
					"color": "#333333",
					"name": "Border"
				},
				{
					"slug": "surface",
					"color": "#1e1e1e",
					"name": "Surface"
				}
			],
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"duotone": [
				{
					"colors": ["#151515", "#a0a0a0"],
					"slug": "tufte-portrait",
					"name": "Portrait"
				},
				{
					"colors": ["#666666", "#fffff8"],
					"slug": "tufte-portrait-light",
					"name": "Portrait Light"
				}
			]
		},
		"typography": {
			"fluid": false,
			"fontFamilies": [
				{
					"fontFamily": "'ET Book', Georgia, 'Palatino Linotype', Palatino, 'Book Antiqua', serif",
					"name": "Serif",
					"slug": "serif",
					"fontFace": [
						{
							"fontFamily": "ET Book",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "optional",
							"src": ["file:./assets/fonts/et-book/et-book-roman-line-figures.woff"]
						},
						{
							"fontFamily": "ET Book",
							"fontWeight": "400",
							"fontStyle": "italic",
							"fontDisplay": "optional",
							"src": ["file:./assets/fonts/et-book/et-book-display-italic-old-style-figures.woff"]
						},
						{
							"fontFamily": "ET Book",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "optional",
							"src": ["file:./assets/fonts/et-book/et-book-bold-line-figures.woff"]
						}
					]
				},
				{
					"fontFamily": "Consolas, 'Liberation Mono', Menlo, Courier, monospace",
					"name": "Monospace",
					"slug": "monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.9rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1.3125rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "3rem",
					"name": "Huge"
				}
			],
			"defaultFontSizes": false
		},
		"spacing": {
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "20",
					"size": "0.5rem",
					"name": "2X-Small"
				},
				{
					"slug": "30",
					"size": "0.75rem",
					"name": "X-Small"
				},
				{
					"slug": "40",
					"size": "1rem",
					"name": "Small"
				},
				{
					"slug": "50",
					"size": "1.5rem",
					"name": "Medium"
				},
				{
					"slug": "60",
					"size": "2rem",
					"name": "Large"
				},
				{
					"slug": "70",
					"size": "3rem",
					"name": "X-Large"
				},
				{
					"slug": "80",
					"size": "4rem",
					"name": "2X-Large"
				}
			],
			"units": ["px", "em", "rem", "%", "vw", "vh"]
		},
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "650px",
			"wideSize": "1000px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": []
		},
		"custom": {
			"transition": "0.3s cubic-bezier(0.4, 0, 0.2, 1)"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--serif)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--50)",
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "400",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"letterSpacing": "-0.01em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-hover)"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--primary-hover)"
					},
					"outline": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--background)"
				},
				"typography": {
					"fontSize": "0.9rem",
					"fontFamily": "inherit"
				},
				"border": {
					"radius": "4px",
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--primary)"
				},
				"spacing": {
					"padding": {
						"top": "0.5rem",
						"bottom": "0.5rem",
						"left": "1.25rem",
						"right": "1.25rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-hover)",
						"text": "var(--wp--preset--color--background)"
					},
					"border": {
						"color": "var(--wp--preset--color--primary-hover)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--primary-hover)",
						"text": "var(--wp--preset--color--background)"
					},
					"outline": {
						"color": "var(--wp--preset--color--primary)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"blocks": {
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "400",
					"letterSpacing": "-0.01em",
					"lineHeight": "1.2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/site-tagline": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "1rem",
					"lineHeight": "1.2"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "400",
					"letterSpacing": "-0.01em"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--foreground)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--primary)"
							}
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontFamily": "var(--wp--preset--font-family--monospace)"
				}
			},
			"core/post-author": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-terms": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--primary)"
						}
					}
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				}
			},
			"core/quote": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "italic",
					"lineHeight": "1.5"
				},
				"border": {
					"width": "0"
				},
				"spacing": {
					"padding": {
						"left": "0",
						"right": "0"
					}
				}
			},
			"core/pullquote": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "italic"
				},
				"border": {
					"width": "0"
				}
			},
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "0.9em"
				},
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--foreground)"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/preformatted": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--monospace)",
					"fontSize": "0.9em"
				},
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--foreground)"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				},
				"border": {
					"width": "0 0 1px 0",
					"style": "solid",
					"color": "currentColor"
				}
			},
			"core/details": {
				"border": {
					"width": "1px",
					"style": "solid",
					"color": "var(--wp--preset--color--border)",
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--40)",
						"bottom": "var(--wp--preset--spacing--40)",
						"left": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/image": {
				"border": {
					"radius": "0"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "0"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
